{
  "name": "frontend-proto",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "env-cmd -f .env.local vite",
    "start:check": "npm run lint:boundary && npm run typecheck && env-cmd -f .env.local vite",
    "preview": "vite preview --outDir dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:boundary": "eslint -c eslint.boundary.config.js \"src/pages/**/*.{ts,tsx}\"",
    "lint:boundary:spp": "eslint -c eslint.boundary.config.js \"src/pages/spp/**/*.{ts,tsx}\"",
    "lint:boundary:nis": "eslint -c eslint.boundary.config.js \"src/pages/nis/**/*.{ts,tsx}\"",
    "format": "prettier . --write",
    "format:check": "prettier --check .",
    "clean:portal": "node -e \"const fs=require('fs'); fs.rmSync('dist/index.html',{force:true}); fs.rmSync('dist/assets',{recursive:true,force:true});\"",
    "clean:spp": "node -e \"fs.rmSync('dist/spp',{recursive:true,force:true})\"",
    "clean:nis": "node -e \"fs.rmSync('dist/nis',{recursive:true,force:true})\"",
    "clean:all": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run build:all",
    "build:portal": "npm run typecheck && npm run clean:portal && vite build --mode portal",
    "build:spp": "npm run lint:boundary:spp && npm run typecheck && npm run clean:portal && vite build --mode portal && npm run clean:spp && vite build --mode spp",
    "build:nis": "npm run lint:boundary:nis && npm run typecheck && npm run clean:portal && vite build --mode portal && npm run clean:nis && vite build --mode nis",
    "build:all": "npm run lint:boundary && npm run typecheck && npm run clean:all && vite build --mode portal && vite build --mode spp && vite build --mode nis",
    "local": "env-cmd -f .env.local npm run build:all",
    "local:portal": "env-cmd -f .env.local npm run build:portal",
    "local:spp": "env-cmd -f .env.local npm run build:spp",
    "local:nis": "env-cmd -f .env.local npm run build:nis",
    "local:all": "env-cmd -f .env.local npm run build:all",
    "dev": "env-cmd -f .env.dev npm run build:all",
    "dev:portal": "env-cmd -f .env.dev npm run build:portal",
    "dev:spp": "env-cmd -f .env.dev npm run build:spp",
    "dev:nis": "env-cmd -f .env.dev npm run build:nis",
    "dev:all": "env-cmd -f .env.dev npm run build:all",
    "prod": "env-cmd -f .env.prod npm run build:all",
    "prod:portal": "env-cmd -f .env.prod npm run build:portal",
    "prod:spp": "env-cmd -f .env.prod npm run build:spp",
    "prod:nis": "env-cmd -f .env.prod npm run build:nis",
    "prod:all": "env-cmd -f .env.prod npm run build:all"
  },
  "dependencies": {
    "@ant-design/icons": "6.1.0",
    "@ant-design/plots": "2.6.8",
    "@hello-pangea/dnd": "18.0.1",
    "@hookform/resolvers": "5.2.2",
    "@tanstack/react-query": "5.90.16",
    "@tanstack/react-query-devtools": "5.91.2",
    "antd": "6.1.4",
    "axios": "1.13.2",
    "dayjs": "1.11.19",
    "jodit": "4.7.9",
    "jodit-react": "5.2.38",
    "pdfjs-dist": "^3.11.174",
    "qs": "6.14.1",
    "rc-virtual-list": "^3.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.2",
    "react-hook-form": "7.70.0",
    "react-resizable": "^3.1.3",
    "react-router-dom": "7.11.0",
    "uuid": "13.0.0",
    "vite-plugin-svgr": "^4.5.0",
    "xlsx": "0.18.5",
    "zod": "3.25.76",
    "zustand": "5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "25.0.3",
    "@types/qs": "6.14.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.50.1",
    "@typescript-eslint/parser": "8.50.1",
    "@vitejs/plugin-react": "5.1.2",
    "autoprefixer": "10.4.20",
    "env-cmd": "11.0.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "postcss": "8.4.47",
    "prettier": "3.7.4",
    "sass": "1.97.2",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.3",
    "vite": "7.3.0",
    "vite-tsconfig-paths": "6.0.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "4.54.0"
  }
}
